# Example environment variables for MPesa Daraja sandbox
# Copy to .env and fill values from your Safaricom Daraja sandbox account
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
BUSINESS_SHORTCODE=174379
PASSKEY=your_passkey_here
# Publicly-reachable callback URL for STK Push result (use ngrok during local testing)
CALLBACK_URL=https://your-public-url.ngrok.io/api/mpesa/webhook
PORT=3000
